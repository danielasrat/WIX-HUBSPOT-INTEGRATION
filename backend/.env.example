PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wix_hubspot
REDIS_URL=redis://127.0.0.1:6379

# 32-byte key encoded as base64
TOKEN_ENCRYPTION_KEY=replace-with-base64-32-byte-key
DASHBOARD_API_TOKEN=replace-with-strong-dashboard-token
WEBHOOK_SHARED_SECRET=replace-with-strong-webhook-secret

HUBSPOT_CLIENT_ID=replace-with-hubspot-client-id
HUBSPOT_CLIENT_SECRET=replace-with-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:5000/api/auth/hubspot/callback

# Optional: required only for live HubSpot -> Wix writes against a real Wix contact bridge
WIX_CONTACTS_API_BASE_URL=
WIX_APP_TOKEN=
